-- Business Question: What are the top 5 most ordered pizza types?
-- Insight: Helps identify the most popular pizzas, enabling better inventory planning and targeted promotions.

SELECT pizza_types.name,
SUM(order_details.quantity) AS quantity
FROM pizza_types
JOIN pizzas
ON pizza_types.pizza_type_id = pizzas.pizza_type_id
JOIN order_details
ON order_details.pizza_id = pizzas.pizza_id
GROUP BY pizza_types.name
ORDER BY quantity DESC
LIMIT 5;

-- Expected Outcome:
-- Top 5 most ordered pizzas include:
-- Barbecue Chicken Pizza
-- California Chicken Pizza
-- Big Meat Pizza
-- Classic Deluxe Pizza
-- Hawaiian Pizza
